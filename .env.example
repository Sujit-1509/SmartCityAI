# JanSevaAI API Configuration
# Copy this file to .env and replace the values with your actual AWS endpoints

# The base URL for your API Gateway (e.g., https://abc123xyz.execute-api.ap-south-1.amazonaws.com/prod)
VITE_API_BASE_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# Public base URL for complaint images served from S3 (trailing slash optional)
VITE_S3_PUBLIC_BASE_URL=https://your-image-bucket.s3.ap-south-1.amazonaws.com

# Optional: set true only in development environments where mock fallback is acceptable
VITE_ENABLE_MOCK_FALLBACK=false

# ── Local Cognito-style JWT (no AWS). When true, login/OTP never hit the API; apiClient still sends Bearer token.
# Copy to .env.local and set VITE_USE_LOCAL_AUTH=true for offline auth. Revert by removing or setting false.
VITE_USE_LOCAL_AUTH=false
# Must match backend JWT_SECRET when calling a local or deployed API that verifies HS256 the same way as backend/auth.
VITE_LOCAL_JWT_SECRET=JanSevaAI-fallback-secret-key-12345
# Optional Cognito-like claims
# VITE_LOCAL_JWT_ISS=https://cognito-idp.localhost/local_ap-south-1_localPool
# VITE_LOCAL_JWT_AUD=jansevaai-web-local
